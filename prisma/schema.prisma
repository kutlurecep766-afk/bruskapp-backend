generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  domain       String?  @unique
  siteTitle    String   @default("")
  primaryColor String   @default("#6366f1")
  secondaryColor String @default("#1e1b4b")
  logoUrl      String   @default("")
  isConfigured Boolean  @default(false)
  storefrontConfig Json @default("{}")
  apiKeys      Json     @default("{}")
  features      Json     @default("{}")
  messageCredit Int      @default(0)
  aiEnabled Boolean @default(true)
  einvoiceConfig Json   @default("{}")
  webchatConfig Json     @default("{}")
  adminChatId   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  messages     Message[]
  paymentTransactions PaymentTransaction[]
  whatsappConfig TenantWhatsAppConfig?
  instagramConfig TenantInstagramConfig?
  zernioConnection ZernioConnection?
  telegramConfig TelegramConfig?
  errorLogs     ErrorLog[]
  creditLogs    CreditLog[]
  weeklyWheels  WeeklyWheel[]
  leads        Lead[]
}

model PaymentTransaction {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchantOid   String   @unique
  amount        Int
  currency      String   @default("TL")
  status        String   @default("pending")
  cardBrand     String?
  installment   Int?
  description   String?
  customerEmail String?
  customerName  String?
  customerPhone String?
  linkId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, createdAt])
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  passwordHash        String
  name                String           @default("")
  role                String           @default("USER")
  permissions         String[]
  tenantId            String
  tenant              Tenant           @relation(fields: [tenantId], references: [id])
  twoFactor           TwoFactorSecret?
  refreshTokens       RefreshToken[]
  bruteForceAttempts  Int              @default(0)
  status              String   @default("active")
  bruteForceBannedAt  DateTime?
  loginAttempts       LoginAttempt[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model TwoFactorSecret {
  id        String   @id @default(uuid())
  secret    String
  verified  Boolean  @default(false)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  success   Boolean
  ip        String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  tenantId  String?
  createdAt DateTime @default(now())

  @@index([tenantId, read])
  @@index([tenantId, createdAt])
}

model Order {
  id              Int      @id @default(autoincrement())
  tenantId        String
  platform        String
  customerName    String
  customerContact String?
  products        Json
  totalAmount     Float
  currency        String   @default("TRY")
  status          String   @default("pending")
  note            String?
  tableNumber     Int?
  waiterId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, waiterId])
}

model Appointment {
  id              Int      @id @default(autoincrement())
  tenantId        String
  platform        String   @default("webchat")
  customerName    String
  customerContact String?
  date            DateTime
  time            String?
  service         String   @default("")
  notes           String   @default("")
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model Reservation {
  id              Int      @id @default(autoincrement())
  tenantId        String
  platform        String   @default("webchat")
  customerName    String
  customerContact String?
  date            DateTime
  time            String?
  guests          Int      @default(2)
  tableNumber     Int?
  notes           String   @default("")
  status          String   @default("pending")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
}

model Message {
  id        String   @id @default(uuid())
  platform  String
  from      String
  fromName  String?
  content   String
  direction String @default("incoming")
  messageId String?
  status    String   @default("sent")
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

model ConversationRead {
  id        String   @id @default(uuid())
  tenantId  String
  platform  String
  from      String
  lastReadAt DateTime @default(now())

  @@unique([tenantId, platform, from])
}

model Lead {
  id           Int      @id @default(autoincrement())
  sessionId    String
  name         String   @default("")
  phone        String   @default("")
  email        String   @default("")
  needs        String   @default("")
  status       String   @default("yeni")
  notes        String   @default("")
  conversation Json     @default("[]")
  source       String   @default("webchat")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([status, createdAt])
  @@index([tenantId])
}

model TenantWhatsAppConfig {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accessToken       String
  phoneNumberId     String
  webhookToken      String
  active            Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TenantInstagramConfig {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accessToken         String
  igBusinessAccountId String
  webhookToken        String
  active              Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model NotificationPreference {
  id         String   @id @default(uuid())
  tenantId   String   @unique
  newOrder   Boolean  @default(true)
  lowStock   Boolean  @default(true)
  newMessage Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  message   String
  status    String   @default("pending")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  createdBy String?
}

model ZernioConnection {
  id            String   @id @default(uuid())
  tenantId      String   @unique
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  profileId     String?
  platforms     Json     @default("[]")
  webhookSecret String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TelegramConfig {
  id        String   @id @default(uuid())
  tenantId  String   @unique
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  botToken  String
  botInfo   Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ErrorLog {
  id            String   @id @default(uuid())
  type          String
  platform      String?
  title         String
  message       String
  stack         String?
  metadata      Json     @default("{}")
  acknowledged  Boolean  @default(false)
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([type, createdAt])
  @@index([acknowledged])
}


model CreditLog {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  amount    Int
  reason    String
  adminId   String
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

model WeeklyWheel {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  status    String   @default("pending")
  result    Int?
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([tenantId, status])
}



model Campaign {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  description String   @default("")
  type        String   @default("discount")
  discount    Int?
  code        String?
  startDate   DateTime?
  endDate     DateTime?
  status      String   @default("draft")
  target      String   @default("all")
  sentCount   Int      @default(0)
  clickCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, status])
}

model BulkMessage {
  id          String   @id @default(uuid())
  tenantId    String
  title       String
  message     String
  platform    String   @default("all")
  status      String   @default("draft")
  totalCount  Int      @default(0)
  sentCount   Int      @default(0)
  failedCount Int      @default(0)
  fileData    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, createdAt])
}

model ReminderTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  title     String
  type      String   @default("appointment")
  message   String
  platform  String   @default("all")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, type])
}

model Comment {
  id        String   @id @default(uuid())
  tenantId  String
  platform  String
  commentId String
  author    String
  content   String
  mediaUrl  String?
  status    String   @default("pending")
  reply     String?
  parentId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, platform, status])
}

model ReportSchedule {
  id        String   @id @default(uuid())
  tenantId  String  @unique
  enabled   Boolean  @default(false)
  time      String   @default("09:00")
  lastSent  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
