generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  domain       String?  @unique
  siteTitle    String   @default("")
  primaryColor String   @default("#6366f1")
  secondaryColor String @default("#1e1b4b")
  logoUrl      String   @default("")
  isConfigured Boolean  @default(false)
  storefrontConfig Json @default("{}")
  apiKeys      Json     @default("{}")
  marketplaceApiKeys Json @default("{}")
  features      Json     @default("{}")
  printerConfig Json     @default("{}")
  einvoiceConfig Json   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  messages     Message[]
  paymentTransactions PaymentTransaction[]
  marketplaceProducts MarketplaceProduct[]
  marketplaceOrders MarketplaceOrder[]
  products Product[]
  stockMovements StockMovement[]
  purchaseInvoices PurchaseInvoice[]
  whatsappConfig TenantWhatsAppConfig?
  instagramConfig TenantInstagramConfig?
}

model Product {
  id          Int      @id @default(autoincrement())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  description String   @default("")
  barcode     String   @default("")
  price       Float
  images      Json     @default("[]")
  category    String   @default("")
  stock       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  stockMovements StockMovement[]
  purchaseItems   PurchaseInvoiceItem[]

  @@index([tenantId, barcode])
  @@index([tenantId, active])
  @@index([tenantId, category])
}

model PaymentTransaction {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  merchantOid   String   @unique
  amount        Int
  currency      String   @default("TL")
  status        String   @default("pending")
  cardBrand     String?
  installment   Int?
  description   String?
  customerEmail String?
  customerName  String?
  customerPhone String?
  linkId        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, createdAt])
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  passwordHash        String
  name                String           @default("")
  role                String           @default("USER")
  permissions         String[]
  tenantId            String
  tenant              Tenant           @relation(fields: [tenantId], references: [id])
  twoFactor           TwoFactorSecret?
  refreshTokens       RefreshToken[]
  bruteForceAttempts  Int              @default(0)
  status              String   @default("active")
  bruteForceBannedAt  DateTime?
  loginAttempts       LoginAttempt[]
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
}

model TwoFactorSecret {
  id        String   @id @default(uuid())
  secret    String
  verified  Boolean  @default(false)
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String
  success   Boolean
  ip        String?
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Order {
  id              Int      @id @default(autoincrement())
  tenantId        String
  platform        String
  customerName    String
  customerContact String?
  products        Json
  totalAmount     Float
  currency        String   @default("TRY")
  status          String   @default("pending")
  note            String?
  tableNumber     Int?
  waiterId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId, createdAt])
  @@index([tenantId, status])
  @@index([tenantId, waiterId])
}

model Message {
  id        String   @id @default(uuid())
  platform  String
  from      String
  fromName  String?
  content   String
  direction String @default("incoming")
  messageId String?
  status    String   @default("sent")
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

model Lead {
  id           Int      @id @default(autoincrement())
  sessionId    String
  name         String   @default("")
  phone        String   @default("")
  email        String   @default("")
  needs        String   @default("")
  status       String   @default("yeni")
  notes        String   @default("")
  conversation Json     @default("[]")
  source       String   @default("webchat")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sessionId])
  @@index([status, createdAt])
}

model MarketplaceProduct {
  id              Int      @id @default(autoincrement())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform        String
  barcode         String
  title           String
  price           Float
  stock           Int
  currency        String   @default("TRY")
  description     String?
  images          Json     @default("[]")
  category        String?
  brand           String?
  marketplaceId   String?
  syncAt          DateTime @default(now())

  @@unique([tenantId, platform, barcode])
  @@index([tenantId, platform])
}


model MarketplaceOrder {
  id                  Int      @id @default(autoincrement())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform            String
  marketplaceOrderId  String   @unique
  orderNumber         String?
  customerName        String
  customerPhone       String?
  customerEmail       String?
  customerContact     String?  @ignore
  deliveryAddress     Json?
  products            Json     @ignore
  totalAmount         Float
  discountPrice       Float    @default(0)
  shippingPrice       Float    @default(0)
  currency            String   @default("TRY")
  paymentType         String?
  status              String   @default("pending")
  marketplaceStatus   String?
  cargoStatus         String?
  cargoCompany        String?
  cargoTracking       String?
  paymentStatus       String?
  isPickedUp          Boolean  @default(false)
  note                String?
  rawPayload          Json?
  orderDate           DateTime?
  platformCreatedAt   DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  items               MarketplaceOrderItem[]

  @@index([tenantId, platform, createdAt])
}

model MarketplaceOrderItem {
  id              Int      @id @default(autoincrement())
  orderId         Int
  order           MarketplaceOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  platformItemId  String?
  sku             String?
  barcode         String?
  title           String
  quantity        Int
  price           Float
  options         Json?
  createdAt       DateTime @default(now())

  @@index([orderId])
}

model StockMovement {
  id          Int      @id @default(autoincrement())
  tenantId    String
  productId   Int
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  type        String   // ADD, DEDUCT, SYNC_FROM_MARKETPLACE, PURCHASE_INVOICE, ORDER, MANUAL
  quantity    Int      // positive for add, negative for deduct
  balance     Int      // stock balance after this movement
  reference   String?  // invoice number, order id, etc
  note        String?
  createdById String?
  createdAt   DateTime @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@index([productId])
}

model PurchaseInvoice {
  id           Int      @id @default(autoincrement())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoiceNo    String
  supplier     String
  date         DateTime
  totalAmount  Float
  currency     String   @default("TRY")
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  items        PurchaseInvoiceItem[]

  @@index([tenantId, createdAt])
}

model PurchaseInvoiceItem {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   Int
  product     Product  @relation(fields: [productId], references: [id])
  barcode     String   @default("")
  productName String
  quantity    Int
  unitPrice   Float
  totalPrice  Float

  @@index([invoiceId])
  @@index([productId])
}

model TenantWhatsAppConfig {
  id                String   @id @default(uuid())
  tenantId          String   @unique
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accessToken       String
  phoneNumberId     String
  webhookToken      String
  active            Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TenantInstagramConfig {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  accessToken         String
  igBusinessAccountId String
  webhookToken        String
  active              Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
